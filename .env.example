# Playwright Tests — Environment Variables
# Copy this file to .env and fill in your credentials

# Base URL (login page)
BASE_URL=https://client.your-app-domain.com

# API Base URL (for API tests)
API_BASE_URL=https://api.your-app-domain.com

# Admin credentials (required)
ADMIN_LOGIN=admin@example.com
ADMIN_PASSWORD=your-admin-password

# Second admin (optional, for parallel worker tests)
ADMIN2_LOGIN=admin2@example.com
ADMIN2_PASSWORD=your-admin2-password

# Regular user credentials (required for user role tests)
USER_LOGIN=user@example.com
USER_PASSWORD=your-user-password

# Manager credentials (optional, for manager role tests)
MANAGER_LOGIN=manager@example.com
MANAGER_PASSWORD=your-manager-password

# Head of Department credentials (optional, for head role tests)
# Руководитель отдела - обычно имеет ограниченные права по сравнению с admin
HEAD_LOGIN=head@example.com
HEAD_PASSWORD=your-head-password

# Support credentials (optional, partial profile — no position/department/manager)
SUPPORT_LOGIN=support@example.com
SUPPORT_PASSWORD=your-support-password

# Test user password (for seed scripts that fill questionnaires as receivers)
# Пароль активных сотрудников в тестовой среде
TEST_USER_PASSWORD=your-test-password

# SSO test user (Auth0 / OpenID Connect)
# Пользователь должен существовать в приложении и в IAM-провайдере
SSO_USER_LOGIN=sso-user@your-domain.com
SSO_USER_PASSWORD=your-sso-password
SSO_AUTH0_DOMAIN=your-tenant.eu.auth0.com
SSO_CLIENT_ID=your-auth0-client-id
SSO_CLIENT_SECRET=your-auth0-client-secret

# Fast login via API (cookie injection instead of UI form, ~10x faster)
# Set to 0 to disable and always use UI login
# AUTH_FAST_LOGIN=1

# Debug options (optional)
# AUTH_DEBUG=1
# SECURITY_DISCOVERY=1

# TestRail integration (for scripts/testrail CLI)
TESTRAIL_URL=your-testrail.testrail.io
TESTRAIL_USER=your-email@example.com
TESTRAIL_API_KEY=your-api-key
TESTRAIL_PROJECT_ID=2
TESTRAIL_SUITE_ID=2

# Database (for data verification in tests)
# Рекомендуется создать read-only пользователя для тестов
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=test_readonly
DB_PASSWORD=your-db-password
