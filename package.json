{
  "name": "playwright-tests",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean:allure": "rimraf allure-results",
    "clean": "node scripts/cleanup-artifacts.js",
    "clean:dry": "node scripts/cleanup-artifacts.js --dry-run",
    "clean:all": "node scripts/cleanup-artifacts.js --all",
    "test": "playwright test",
    "ui": "playwright test --ui",
    "headed": "playwright test --headed",
    "debug": "playwright test --debug",
    "test:functional": "playwright test --project=ui --project=api tests/functional",
    "test:functional:surveys": "playwright test --project=ui tests/functional/surveys",
    "test:functional:feedback": "playwright test --project=ui tests/functional/feedback",
    "test:functional:objectives": "playwright test --project=ui tests/functional/objectives",
    "test:functional:org-structure": "playwright test --project=ui tests/functional/org-structure",
    "test:functional:profile": "playwright test --project=ui tests/functional/profile",
    "test:functional:performance-review": "playwright test --project=ui tests/functional/performance-review",
    "test:functional:calibration": "playwright test --project=ui tests/functional/performance-review/calibration",
    "test:nightly": "playwright test --project=nightly",
    "test:security": "playwright test --project=security",
    "test:smoke": "playwright test --project=smoke-api --project=smoke-ui",
    "test:smoke:api": "playwright test --project=smoke-api",
    "test:smoke:ui": "playwright test --project=smoke-ui",
    "test:sanity": "playwright test --project=sanity",
    "test:sanity:api": "playwright test --project=sanity-api",
    "test:api:batched": "node scripts/run-api-batched.mjs",
    "test:functional:virtual-currency": "playwright test --project=regression tests/functional/virtual-currency --workers=1",
    "test:setup": "playwright test tests/functional/virtual-currency/enable-virtual-currency.spec.js --grep @setup",
    "seed:survey": "node scripts/seed-survey-data.js",
    "seed:survey:check": "node scripts/seed-survey-data.js --check",
    "seed:survey:cleanup": "node scripts/seed-survey-data.js --cleanup",
    "seed:pr": "node scripts/seed-performance-review-data.js",
    "seed:pr:check": "node scripts/seed-performance-review-data.js --check",
    "seed:pr:cleanup": "node scripts/seed-performance-review-data.js --cleanup",
    "seed:calibration": "node scripts/seed-calibration-data.js",
    "seed:calibration:full": "node scripts/seed-calibration-data.js --full",
    "seed:calibration:check": "node scripts/seed-calibration-data.js --check",
    "seed:calibration:cleanup": "node scripts/seed-calibration-data.js --cleanup",
    "test:api:survey": "playwright test tests/functional/api/survey*.spec.js",
    "test:api:pr": "playwright test tests/functional/api/performance-review*.spec.js",
    "test:critical": "playwright test --grep @critical",
    "test:module:surveys": "playwright test --grep @surveys",
    "test:module:feedback": "playwright test --grep @feedback",
    "test:module:objectives": "playwright test --grep @objectives",
    "test:module:performance-review": "playwright test --grep @performance-review",
    "report": "playwright show-report",
    "allure:gen": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results",
    "allure:history": "node -e \"const fs=require('fs');const d='allure-history';if(fs.existsSync(d)){console.log('Доступные прогоны:');fs.readdirSync(d).filter(f=>f.startsWith('run_')).sort().reverse().forEach((f,i)=>console.log(i+1+'. '+f))}else{console.log('История пуста')}\"",
    "allure:serve:run": "node -e \"const p=process.argv[1];if(!p){console.log('Укажите папку: npm run allure:serve:run run_2025-01-16_12-00-00');process.exit(1)}require('child_process').execSync('allure serve allure-history/'+p,{stdio:'inherit'})\"",
    "load:test": "playwright test --project=load",
    "load:test:baseline": "playwright test --project=load-baseline",
    "load:test:volume": "playwright test --project=load-volume",
    "load:test:stress": "playwright test --project=load-stress",
    "load:test:ui": "playwright test --project=load-ui",
    "load:test:pr": "playwright test --project=load tests/load/**/pr-*.spec.js",
    "load:test:survey": "playwright test --project=load tests/load/**/survey-*.spec.js",
    "load:seed:verify": "node tests/load/seed/seed-verify.js",
    "load:seed:pr": "node tests/load/seed/seed-large-pr.js",
    "load:seed:pr:dry": "node tests/load/seed/seed-large-pr.js --dry-run",
    "load:seed:pr:cleanup": "node tests/load/seed/seed-large-pr.js --cleanup",
    "load:seed:pr:answers": "node tests/load/seed/seed-large-pr-with-answers.js",
    "load:seed:pr:answers:dry": "node tests/load/seed/seed-large-pr-with-answers.js --dry-run",
    "load:seed:pr:answers:cleanup": "node tests/load/seed/seed-large-pr-with-answers.js --cleanup",
    "load:test:export": "npx.cmd playwright test tests/load/export/ --project=load",
    "load:test:dashboard:large": "npx.cmd playwright test tests/load/dashboard/ --project=load",
    "load:seed:survey": "node tests/load/seed/seed-large-survey.js",
    "load:seed:survey:dry": "node tests/load/seed/seed-large-survey.js --dry-run",
    "load:seed:survey:cleanup": "node tests/load/seed/seed-large-survey.js --cleanup",
    "load:seed:all": "node tests/load/seed/seed-large-pr.js && node tests/load/seed/seed-large-survey.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:quality": "node scripts/lint-test-quality.cjs --all",
    "lint:quality:critical": "node scripts/lint-test-quality.cjs --all --critical-only",
    "format": "prettier -w .",
    "testrail": "node scripts/testrail/cli.cjs",
    "testrail:modules": "node scripts/testrail/cli.cjs list-modules",
    "testrail:sections": "node scripts/testrail/cli.cjs list-sections",
    "testrail:export": "node scripts/testrail/cli.cjs export",
    "test:testrail": "set TESTRAIL_REPORT=1&& playwright test --project=regression",
    "test:testrail:smoke": "set TESTRAIL_REPORT=1&& playwright test --project=smoke-api --project=smoke-ui"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/mcp": "^0.0.63",
    "@playwright/test": "^1.55.1",
    "@types/node": "^24.6.0",
    "@zealteam/testrail-reporter": "^1.0.17",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1",
    "dotenv": "^17.2.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.2.2",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "md-to-pdf": "^5.2.5",
    "mysql2": "^3.16.2",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "xlsx": "^0.18.5"
  }
}
